-- select 3 / mitme tabelite põhjal
SELECT 
    lp.nimi AS lapsenimi,
    l.nimi AS loomanimi,
    v.koht
FROM laps AS lp
INNER JOIN loom AS l
    ON l.lapsID = lp.lapsID

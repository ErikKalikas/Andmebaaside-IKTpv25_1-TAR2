	Select * from	 laps


	--loom
	CREATE TABLE loom(
    loomID int not null PRIMARY KEY identity,
    nimi varchar(40) not null,
    kaal smallint,
    lapsID int,
    FOREIGN KEY (lapsID) REFERENCES laps(lapsID)  
   );

   insert INTO loom(nimi, kaal, lapsID)
   values
   ('kaas vasil', 4 , 1),
   ('kaas Test', 3, 4),
   ('kaas kilja', 2, 3),
   ('kaas kärbes', 1, 2);
   SELECT * from loom

-- Alias kasutamine
SELECT l.nimi, l.kaal 
FROM loom AS l;


-- INNER JOIN (õige viis)
SELECT * FROM laps AS lp
INNER JOIN loom AS l
ON l.lapsID = lp.lapsID;


-- ainult nimed
SELECT 
    lp.nimi AS lapsenimi,
    l.nimi AS loomanimi,
    l.kaal
FROM laps AS lp
INNER JOIN loom AS l
ON l.lapsID = lp.lapsID;


-- LEFT JOIN (näitab kõik lapsed isegi kui neil pole looma)
SELECT 
    lp.nimi AS lapsenimi,
    l.nimi AS loomanimi,
    l.kaal
FROM laps AS lp
LEFT JOIN loom AS l
ON l.lapsID = lp.lapsID;


-- RIGHT JOIN (näitab kõik loomad isegi kui laps puudub)
SELECT 
    lp.nimi AS lapsenimi,
    l.nimi AS loomanimi,
    l.kaal
FROM laps AS lp
RIGHT JOIN loom AS l
ON l.lapsID = lp.lapsID;

	--pilt konspelti

	--right join
  
  --CROSS JOIN korrutatud tabelid
  SELECT 
    lp.nimi AS lapsenimi,
    l.nimi AS loomanimi,
    l.kaal
FROM laps AS lp
CROSS JOIN loom AS l



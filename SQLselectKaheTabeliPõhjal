--select kahe tabeli põhjal

--laps/loom tabeid

CREATE TABLE laps(
    lapsID int not null PRIMARY KEY identity,
    nimi varchar(40) not null,
    pikkus smallint,
    synniaasta int null,
    synnilinn varchar(15)
    );
